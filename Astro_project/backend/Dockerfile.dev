FROM node:20-alpine

WORKDIR /app

# Instalamos dependencias primero para aprovechar la caché de capas
COPY package*.json ./
RUN npm install

# Copiamos el resto del código
COPY . .

# Exponemos el puerto de tu API (ajusta si usas otro)
EXPOSE 3000

# Usamos nodemon o el script de dev que tengas en package.json
CMD ["npm", "run", "dev"]