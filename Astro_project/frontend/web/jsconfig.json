{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "lib": [
      "esnext",
      "dom",
      "dom.iterable",
      "scripthost"
    ],
    "checkJs": false
  },
  "include": [
    "src/**/*",
    "src/**/*.vue"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/pages/training/multiplayer.vue",
    "src/components/games/EmojiHistory.vue",
    "src/components/games/EmojiPicker.vue",
    "src/components/games/HieroglyphDisplay.vue",
    "src/components/games/scratch_radio.vue",
    "src/components/games/scratch_radio_utf8.vue",
    "src/components/games/scratch_symmetry.vue",
    "src/components/games/scratch_symmetry_utf8.vue",
    "src/components/games/MultiplayerScoreSystem.vue",
    "src/components/games/radar_scan_old.vue",
    "src/components/games/radio_signal_old_design.vue",
    "src/components/games/radio_signal_old_logic.vue",
    "src/pages/friends/old_lobby.vue",
    "src/pages/friends/old_lobby_v2.vue",
    "src/pages/friends/old_lobby_fe.vue",
    "src/pages/friends/old_lobby_fe_utf8.vue",
    "src/pages/friends/temp_*.vue"
  ]
}